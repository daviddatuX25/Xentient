# MQTT
MQTT_BROKER_URL=mqtt://localhost:1883
NODE_ID=node-01

# Audio WebSocket
WS_PORT=8080

# Control server (HTTP API + browser test page)
CONTROL_PORT=3000

# MCP Transport — set MCP_DUAL=true to enable both stdio + SSE
# Set MCP_TRANSPORT=sse for SSE only, or leave unset for stdio only
MCP_DUAL=false
MCP_TRANSPORT=stdio
MCP_PORT=3001

# STT
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here

# TTS
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=your_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# LLM (basic mode — direct provider call)
LLM_PROVIDER=openai

# Artifact storage (relative paths in MQTT messages are resolved from this)
XENTIENT_ARTIFACTS_PATH=./var/artifacts

# Brain Router mode (basic | hermes | hermes+mem0 | openclaw | archon)
# Demo: basic only. Post-demo: add Hermes/Mem0/OpenClaw/Archon adapters.
BRAIN_MODE=basic