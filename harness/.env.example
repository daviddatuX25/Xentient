# MQTT
MQTT_BROKER_URL=mqtt://localhost:1883
NODE_ID=node-01

# Audio WebSocket
WS_PORT=8080
# Camera WebSocket (falls back from CAMERA_WS_PORT upward)
CAMERA_WS_PORT=8081

# Control server (HTTP API + browser test page)
CONTROL_PORT=3000

# Port fallback: how many ports to try when preferred port is in use (default: 20)
# PORT_FALLBACK_RANGE=20

# STT
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here

# TTS
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=your_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# LLM (basic mode — direct provider call)
# LLM_API_KEY takes priority over OPENAI_API_KEY for provider initialization
# LLM_BASE_URL enables OpenAI-compatible providers (MiniMax, OpenRouter, etc.)
# LLM_MODEL overrides the default model from config/default.json
LLM_PROVIDER=openai
# LLM_API_KEY=your_key_here
# LLM_BASE_URL=https://api.minimax.io/v1
# LLM_MODEL=MiniMax-M2.7

# Artifact storage (relative paths in MQTT messages are resolved from this)
XENTIENT_ARTIFACTS_PATH=./var/artifacts

# Brain Router mode (basic | hermes | hermes+mem0 | openclaw | archon)
# Demo: basic only. Post-demo: add Hermes/Mem0/OpenClaw/Archon adapters.
BRAIN_MODE=basic