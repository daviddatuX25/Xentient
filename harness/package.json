{
  "name": "xentient-harness",
  "version": "1.0.0",
  "description": "Xentient Harness - Intelligence layer between hardware and Cloud AI",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:monolith": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:core": "ts-node-dev --respawn --transpile-only src/core.ts",
    "dev:brain": "ts-node-dev --respawn --transpile-only src/brain-basic.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:core": "node dist/core.js",
    "start:brain": "node dist/brain-basic.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "sim:node": "bun run sim/node-base.ts",
    "sim:brain": "bun run sim/brain.ts",
    "fixtures:verify": "bun run src/shared/contracts-verify.ts",
    "fixtures:regen-schemas": "bun run src/shared/contracts-schemas.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@deepgram/sdk": "^3.8.0",
    "@google/generative-ai": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.7",
    "elevenlabs": "^1.10.0",
    "mqtt": "^5.10.0",
    "node-cron": "^4.2.1",
    "openai": "^4.77.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "ws": "^8.18.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/mqtt": "^2.5.0",
    "@types/node": "^22.13.0",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}
